---
---
<section class="hero" id="home">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="hero-tag">Late-Night Tacos · Dunedin, FL</span>
    <h1>Enrico's<br/>Tacos</h1>
    <p class="hero-sub">
      Authentic flavors, open late. Birria, Gorditas, Suadero and more —
      right in the heart of Dunedin.
    </p>
    <div class="hero-hours">
      <span class="hours-dot"></span>
      Mon – Sat &nbsp;·&nbsp; 4:00 PM – 1:00 AM
    </div>
    <div class="hero-ctas">
      <a href="tel:+17274095348" class="btn btn-primary">📞 Call Now</a>
      <a
        href="https://maps.google.com/?q=916+Patricia+Ave+Ste+D,+Dunedin,+FL+34698"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary"
      >📍 Get Directions</a>
      <a
        href="https://www.yelp.com/biz/enricos-tacos-dunedin"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-yelp"
      >★ View on Yelp</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--charcoal);
    background-image:
      radial-gradient(ellipse at 60% 40%, rgba(185,28,28,0.25) 0%, transparent 65%),
      radial-gradient(ellipse at 20% 80%, rgba(45,106,79,0.2) 0%, transparent 60%);
    padding: 5rem 1.25rem 4rem;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        45deg,
        rgba(255,255,255,0.015) 0px,
        rgba(255,255,255,0.015) 1px,
        transparent 1px,
        transparent 40px
      );
    pointer-events: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-tag {
    display: inline-block;
    background: rgba(212,160,23,0.18);
    border: 1px solid var(--gold);
    color: var(--gold-light);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 12vw, 7rem);
    color: var(--cream);
    line-height: 1.0;
    margin-bottom: 1.25rem;
    text-shadow: 0 4px 24px rgba(0,0,0,0.5);
    letter-spacing: -0.01em;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #c8c0ad;
    max-width: 500px;
    margin: 0 auto 1.75rem;
    line-height: 1.65;
  }

  .hero-hours {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    color: #d4cfbf;
    font-size: 0.9rem;
    padding: 0.45rem 1.1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  .hours-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px #4ade80;
    flex-shrink: 0;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .hero-ctas .btn {
      width: 100%;
      max-width: 280px;
    }
  }
</style>
