---
const base = import.meta.env.BASE_URL;
---
<section class="hero" id="home">
  <div class="hero-bg">
    <img
      src={`${base}images/pexels-lucia-photography-in-progress-cano-318039738-31632714.jpg`}
      alt="Birria tacos with consommé dipping bowl"
      class="hero-photo"
    />
    <div class="hero-gradient"></div>
  </div>

  <div class="hero-content">
    <span class="hero-tag">Patricia Ave · Dunedin, FL</span>
    <h1>Late-Night Tacos<br/>in Dunedin</h1>
    <p class="hero-sub">
      A local taqueria serving tacos, birria, gorditas, flautas,
      and more on Patricia Ave — open late, every night of the week.
    </p>
    <div class="hero-hours">
      <span class="hours-dot"></span>
      Open Mon – Sat &nbsp;·&nbsp; 4:00 PM – 1:00 AM
    </div>
    <div class="hero-ctas">
      <a href="tel:+17274095348" class="btn btn-primary">📞 Call Now</a>
      <a
        href="https://maps.google.com/?q=916+Patricia+Ave+Ste+D,+Dunedin,+FL+34698"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary"
      >📍 Get Directions</a>
      <a
        href="https://www.yelp.com/biz/enricos-tacos-dunedin"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-yelp"
      >★ View on Yelp</a>
    </div>
  </div>
</section>
<div class="tile-divider"></div>

<style>
  .hero {
    position: relative;
    min-height: 96vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 6rem 1.25rem 5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(28, 25, 23, 0.55) 0%,
      rgba(28, 25, 23, 0.70) 50%,
      rgba(28, 25, 23, 0.88) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 740px;
    margin: 0 auto;
  }

  .hero-tag {
    display: inline-block;
    background: rgba(212, 135, 15, 0.2);
    border: 1px solid var(--amber);
    color: var(--amber-light);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.38rem 1.1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    font-weight: 700;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 10vw, 6rem);
    color: var(--crema);
    line-height: 1.05;
    margin-bottom: 1.25rem;
    text-shadow: 0 3px 20px rgba(0,0,0,0.6);
    letter-spacing: -0.01em;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.4vw, 1.15rem);
    color: #d6cfc0;
    max-width: 520px;
    margin: 0 auto 1.75rem;
    line-height: 1.7;
  }

  .hero-hours {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: rgba(255,255,255,0.09);
    border: 1px solid rgba(255,255,255,0.15);
    color: #d6cfc0;
    font-size: 0.88rem;
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 2.25rem;
    letter-spacing: 0.02em;
  }

  .hours-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
    flex-shrink: 0;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .hero-ctas .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
