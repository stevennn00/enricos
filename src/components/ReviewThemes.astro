---
const themes = [
  {
    icon: "🌮",
    heading: "Birria That Brings People Back",
    body: "The birria tacos and consommé dip come up again and again — it's clearly the dish people drive across town for.",
  },
  {
    icon: "🕐",
    heading: "Dunedin's Late-Night Go-To",
    body: "Open until 1 AM Monday through Saturday, Enrico's fills a real gap for anyone who wants legit food after dark.",
  },
  {
    icon: "🏘️",
    heading: "A Neighborhood Hidden Gem",
    body: "Tucked on Patricia Ave, regulars describe it as the kind of spot that feels like a local secret — in the best way.",
  },
  {
    icon: "💚",
    heading: "Generous Portions, Real Flavor",
    body: "Customers mention hearty servings and flavors rooted in Mexican street-food tradition — straightforward and satisfying.",
  },
];
---
<section class="themes" id="reviews">
  <div class="container">
    <span class="section-label">Community Themes</span>
    <h2 class="section-title">What People Are Saying</h2>
    <p class="section-subtitle">
      Customers mention birria, tacos, friendly service, late-night hours,
      and a casual local feel. Read full reviews on Yelp.
    </p>
    <div class="themes-grid">
      {themes.map((t) => (
        <div class="theme-card">
          <span class="theme-icon">{t.icon}</span>
          <div>
            <h3 class="theme-heading">{t.heading}</h3>
            <p class="theme-body">{t.body}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="yelp-cta">
      <p>Read real customer reviews directly on Yelp:</p>
      <a
        href="https://www.yelp.com/biz/enricos-tacos-dunedin"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-yelp"
      >★ Read Reviews on Yelp</a>
    </div>
  </div>
</section>

<style>
  .themes {
    background: var(--crema);
  }

  .themes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .theme-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.4rem 1.6rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .theme-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .theme-icon {
    font-size: 1.8rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 0.1rem;
  }

  .theme-heading {
    font-size: 1rem;
    font-family: var(--font-heading);
    color: var(--charcoal);
    margin-bottom: 0.4rem;
  }

  .theme-body {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .yelp-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .yelp-cta p {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>
