---
const placeholders = [
  { label: "Owner food photo here", icon: "🌮", hint: "Feature dish" },
  { label: "Menu photo here", icon: "📋", hint: "Full menu board" },
  { label: "Restaurant exterior photo here", icon: "🏠", hint: "Storefront" },
  { label: "Interior photo here", icon: "🪑", hint: "Dining area" },
];
---
<section class="gallery" id="gallery">
  <div class="container">
    <span class="section-label">Gallery</span>
    <h2 class="section-title">A Closer Look</h2>
    <p class="section-subtitle gallery-note">
      Owner-approved photos can replace these placeholders.
    </p>
    <div class="gallery-grid">
      {placeholders.map((p) => (
        <div class="gallery-card">
          <div class="gallery-inner">
            <span class="gallery-icon">{p.icon}</span>
            <span class="gallery-label">{p.label}</span>
            <span class="gallery-hint">{p.hint}</span>
          </div>
        </div>
      ))}
    </div>
    <p class="replace-note">Owner-approved photos can replace these placeholders.</p>
  </div>
</section>

<style>
  .gallery {
    background: var(--white);
  }

  .gallery-note {
    font-style: italic;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .gallery-card {
    aspect-ratio: 4 / 3;
    background: var(--cream-dark);
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }

  .gallery-card:hover {
    border-color: var(--gold);
    background: #fdf3cc;
  }

  .gallery-inner {
    text-align: center;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .gallery-icon {
    font-size: 2.2rem;
    line-height: 1;
  }

  .gallery-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--charcoal);
  }

  .gallery-hint {
    font-size: 0.75rem;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .replace-note {
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: var(--gray);
    text-align: center;
    font-style: italic;
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
