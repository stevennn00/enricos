---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Enrico's Tacos — Late-Night Tacos in Dunedin, FL",
  description = "Authentic late-night tacos in Dunedin, FL. Birria, Gorditas, Suadero, Flautas and more. Open Mon–Sat 4PM–1AM.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <slot />
  </body>
</html>
